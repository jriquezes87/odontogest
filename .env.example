# Copia este archivo como .env para desarrollo local
# En Render, estas variables se configuran en el dashboard del servicio (Environment)

SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos PostgreSQL (Render la genera automaticamente si usas su servicio de DB)
DATABASE_URL=postgres://usuario:clave@localhost:5432/odontogest

# Dominios permitidos para peticiones POST seguras (agregar tu dominio real de Render)
CSRF_TRUSTED_ORIGINS=https://tuapp.onrender.com

# Nombre generico de la app (se puede personalizar por consultorio despues)
MARCA_APP_NOMBRE=OdontoGest

# Opcional: almacenamiento externo para fotos (Cloudflare R2 / AWS S3)
# Dejar vacio mientras no se configure - la app funciona igual con almacenamiento local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
